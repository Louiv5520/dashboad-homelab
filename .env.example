AUTH_SECRET=make-a-long-secret-key-here
AUTH_USERNAME=admin
AUTH_PASSWORD=strong-password
AUTH_COOKIE_SECURE=false

PROXMOX_BASE_URL=https://proxmox.local:8006
PROXMOX_NODE=pve
PROXMOX_TOKEN_ID=root@pam!dashboard
PROXMOX_TOKEN_SECRET=your-token-secret

# Brug enten APP_DOCKER_HOST eller DOCKER_SOCKET_PATH
APP_DOCKER_HOST=
DOCKER_SOCKET_PATH=/var/run/docker.sock
